<div id="bottleneck-quiz" class="mx-auto max-w-2xl">
  <div id="quiz-intro" class="quiz-panel rounded-2xl p-6 md:p-8">
    <div class="mb-2 flex items-center justify-between text-xs font-medium uppercase tracking-wider text-muted">
      <span id="quiz-step-label">Question 1 of 4</span>
      <span id="quiz-percent">0%</span>
    </div>
    <div class="mb-8 h-1.5 w-full overflow-hidden rounded-full bg-white/10">
      <div
        id="quiz-progress"
        class="quiz-progress-bar h-full w-0 rounded-full bg-aquamarine transition-all duration-500 ease-out"
      />
    </div>
    <div id="quiz-question-container" />
  </div>

  <div id="quiz-result" class="hidden" />

  <div id="quiz-email" class="quiz-panel mt-8 hidden rounded-2xl p-6 md:p-8">
    <h3 class="font-display text-xl font-bold">Get your personalized growth roadmap</h3>
    <p class="mt-2 text-sm text-muted">
      Leave your details and we'll show your bottleneck diagnosis plus a tailored next step.
    </p>
    <div class="mt-6" data-hs-form-panel>
      <form class="space-y-5" data-hubspot-form="bottleneckQuiz" id="quiz-hubspot-form">
        <input type="hidden" name="quiz_answers" id="quiz-answers-field" value="" />
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-muted" for="quiz-firstname">First name</label>
            <input
              type="text"
              id="quiz-firstname"
              name="firstname"
              required
              autocomplete="given-name"
              placeholder="Jane"
              class="w-full rounded-lg border border-white/10 bg-pearl px-4 py-3 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none focus:ring-1 focus:ring-aquamarine/30"
            />
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-muted" for="quiz-lastname">Last name</label>
            <input
              type="text"
              id="quiz-lastname"
              name="lastname"
              required
              autocomplete="family-name"
              placeholder="Doe"
              class="w-full rounded-lg border border-white/10 bg-pearl px-4 py-3 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none focus:ring-1 focus:ring-aquamarine/30"
            />
          </div>
        </div>
        <div>
          <label class="mb-1.5 block text-sm font-medium text-muted" for="quiz-email-input">Email</label>
          <input
            type="email"
            id="quiz-email-input"
            name="email"
            required
            class="w-full rounded-lg border border-white/10 bg-pearl px-4 py-3 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none focus:ring-1 focus:ring-aquamarine/30"
          />
        </div>
        <div>
          <label class="mb-1.5 block text-sm font-medium text-muted" for="quiz-company">Company</label>
          <input
            type="text"
            id="quiz-company"
            name="company"
            class="w-full rounded-lg border border-white/10 bg-pearl px-4 py-3 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none focus:ring-1 focus:ring-aquamarine/30"
          />
        </div>
        <button type="submit" class="btn-glow rounded-lg px-6 py-3.5 text-sm font-semibold">
          Get my roadmap
        </button>
      </form>
      <div class="hs-form-success hidden rounded-lg border border-aquamarine/30 bg-bunting/60 p-4 text-sm text-white/90" role="status">
        <p data-hs-success-message></p>
      </div>
    </div>
  </div>
</div>

<script>
  const questions = [
    {
      id: 1,
      text: "Do you know what's actually driving your growth right now?",
      answers: [
        { label: 'No: we rely on gut feeling and manual reporting', value: 'A' },
        { label: "Partially: we have some data but it's incomplete", value: 'B' },
        { label: 'Yes: we have clear tracking, attribution and CRM discipline', value: 'C' },
      ],
      dimension: 'visibility',
    },
    {
      id: 2,
      text: 'How would you describe your pipeline?',
      answers: [
        { label: "Too empty: we depend on referrals and it's unpredictable", value: 'A' },
        { label: 'Inconsistent: some months are great, others are dry', value: 'B' },
        { label: 'Healthy: we generate leads consistently across multiple channels', value: 'C' },
      ],
      dimension: 'demand',
    },
    {
      id: 3,
      text: 'What happens to your leads once you have them?',
      answers: [
        { label: 'Many go cold, follow-up is inconsistent and conversion is low', value: 'A' },
        { label: 'Some convert but the process is unclear and results vary', value: 'B' },
        { label: 'We have a clear process and strong conversion rates', value: 'C' },
      ],
      dimension: 'conversion',
    },
    {
      id: 4,
      text: 'As you grow, does it feel easier or harder to manage?',
      answers: [
        { label: 'Much harder, everything feels more complex and manual', value: 'A' },
        { label: "About the same, we're managing but not systematically", value: 'B' },
        { label: 'Easier: we have systems and processes that scale', value: 'C' },
      ],
      dimension: 'scale',
    },
  ];

  const results = {
    visibility: {
      title: 'Flying Blind',
      bottleneck: 'Visibility',
      diagnosis:
        'Your bottleneck is Visibility. Before generating more demand, you need to build the measurement foundation.',
      description:
        "We build tracking, CRM foundations, and KPI frameworks so you know exactly what drives growth, and what doesn't.",
      cta: 'Explore Growth Readiness →',
      href: '/services/growth-readiness',
      case: { client: 'Easybell', slug: 'easybell', result: '272% decrease in CAC' },
    },
    demand: {
      title: 'Struggling for Demand',
      bottleneck: 'Demand Generation',
      diagnosis:
        'Your bottleneck is Demand Generation. You need a repeatable engine that fills your pipeline on purpose.',
      description:
        'We build demand capture and creation systems (paid acquisition, SEO, and lead generation) that run consistently.',
      cta: 'Explore Growth Generation →',
      href: '/services/growth-generation',
      case: { client: 'Anders Beton', slug: 'anders-beton', result: '0 to 3,000 leads in 3 months' },
    },
    conversion: {
      title: 'Struggling for Conversion',
      bottleneck: 'Conversion',
      diagnosis:
        "Your bottleneck is Conversion. You have demand but it's not turning into revenue efficiently.",
      description:
        'We optimize funnels, implement lead scoring, and align marketing automation with sales to convert more.',
      cta: 'Explore Growth Conversion →',
      href: '/services/growth-conversion',
      case: { client: 'Vandemoortele', slug: 'vandemoortele', result: 'B2C to B2B engine at scale' },
    },
    scale: {
      title: 'Struggling to Scale',
      bottleneck: 'Scalability',
      diagnosis:
        'Your bottleneck is Scalability. Growth is creating complexity. You need systems.',
      description:
        'We build RevOps, forecasting, and commercial operating models so growth scales without chaos.',
      cta: 'Explore Growth Acceleration →',
      href: '/services/growth-acceleration',
      case: { client: 'Easybell', slug: 'easybell', result: '261% MRR uplift' },
    },
    developing: {
      title: 'Your engine is developing',
      bottleneck: 'Next step',
      diagnosis:
        'Your engine is developing. A growth audit will identify the highest-impact next step.',
      description:
        "We'll analyze your current growth setup and pinpoint where to focus for maximum impact.",
      cta: 'Speak to a growth engineer →',
      href: '/contact',
      case: {
        client: 'Brouwerij Van Steenberge',
        slug: 'brouwerij-van-steenberge',
        result: '€65,000 in 24 hours',
      },
    },
  };

  let currentQuestion = 0;
  const answers: Record<string, string> = {};

  const container = document.getElementById('quiz-question-container');
  const progress = document.getElementById('quiz-progress');
  const stepLabel = document.getElementById('quiz-step-label');
  const percentLabel = document.getElementById('quiz-percent');
  const resultEl = document.getElementById('quiz-result');
  const introEl = document.getElementById('quiz-intro');
  const emailEl = document.getElementById('quiz-email');

  function updateProgress() {
    const pct = Math.round((currentQuestion / questions.length) * 100);
    if (progress) progress.style.width = `${pct}%`;
    if (stepLabel) stepLabel.textContent = `Question ${currentQuestion + 1} of ${questions.length}`;
    if (percentLabel) percentLabel.textContent = `${pct}%`;
  }

  function renderQuestion() {
    const q = questions[currentQuestion];
    if (!container) return;

    updateProgress();

    const labels = ['A', 'B', 'C'];
    container.innerHTML = `
      <div class="quiz-question-enter">
        <h3 class="font-display text-xl font-bold leading-snug md:text-2xl">${q.text}</h3>
        <div class="mt-6 space-y-3">
          ${q.answers
            .map(
              (a, i) => `
            <button
              type="button"
              class="quiz-answer flex w-full items-start gap-4 rounded-xl border border-white/10 bg-pearl/60 px-4 py-4 text-left"
              data-value="${a.value}"
              data-dimension="${q.dimension}"
            >
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-aquamarine/30 text-xs font-bold text-aquamarine">${labels[i]}</span>
              <span class="text-sm leading-relaxed text-white/90">${a.label}</span>
            </button>
          `
            )
            .join('')}
        </div>
      </div>
    `;

    container.querySelectorAll('.quiz-answer').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dimension = (btn as HTMLElement).dataset.dimension!;
        const value = (btn as HTMLElement).dataset.value!;
        answers[dimension] = value;
        btn.classList.add('border-aquamarine/60', 'bg-bunting/80');
        currentQuestion++;
        setTimeout(() => {
          if (currentQuestion < questions.length) {
            renderQuestion();
          } else {
            showEmailCapture();
          }
        }, 200);
      });
    });
  }

  function calculateResult() {
    const counts = { A: 0, B: 0, C: 0 };
    Object.values(answers).forEach((v) => counts[v as keyof typeof counts]++);

    if (counts.A >= 2) {
      const aDimensions = Object.entries(answers).filter(([, v]) => v === 'A');
      const firstA = aDimensions[0]?.[0];
      if (firstA && firstA in results) return results[firstA as keyof typeof results];
    }

    if (answers.visibility === 'A') return results.visibility;
    if (answers.demand === 'A') return results.demand;
    if (answers.conversion === 'A') return results.conversion;
    if (answers.scale === 'A') return results.scale;

    return results.developing;
  }

  function formatQuizAnswers() {
    return questions
      .map((q, index) => {
        const value = answers[q.dimension];
        const answer = q.answers.find((a) => a.value === value);
        return `Q${index + 1}: ${q.text}\nA: ${answer?.label || value || '-'}`;
      })
      .join('\n\n');
  }

  function showEmailCapture() {
    if (!introEl || !emailEl || !progress || !percentLabel) return;

    progress.style.width = '100%';
    percentLabel.textContent = '100%';
    introEl.classList.add('hidden');
    emailEl.classList.remove('hidden');

    const answersField = document.getElementById('quiz-answers-field') as HTMLInputElement | null;
    if (answersField) answersField.value = formatQuizAnswers();
  }

  function showResult() {
    const result = calculateResult();
    if (!resultEl || !emailEl) return;

    emailEl.classList.add('hidden');
    resultEl.classList.remove('hidden');

    resultEl.innerHTML = `
      <div class="quiz-question-enter rounded-2xl border border-aquamarine/30 bg-bunting p-6 md:p-8">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-aquamarine">${result.bottleneck}</span>
        <h3 class="font-display mt-3 text-2xl font-bold md:text-3xl">${result.title}</h3>
        <p class="mt-4 text-lg leading-relaxed">${result.diagnosis}</p>
        <p class="mt-4 text-sm leading-relaxed text-muted">${result.description}</p>
        <a href="${result.href}" class="btn-glow mt-8 inline-flex rounded px-6 py-3.5 text-sm font-semibold">
          ${result.cta}
        </a>
      </div>
      <div class="quiz-panel mt-6 rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-wider text-muted">Relevant case study</p>
        <a href="/cases/${result.case.slug}" class="group mt-3 block">
          <span class="font-display text-lg font-bold group-hover:text-aquamarine">${result.case.client}</span>
          <span class="mt-1 block text-aquamarine">${result.case.result}</span>
        </a>
      </div>
    `;
  }

  const quizForm = document.getElementById('quiz-hubspot-form');
  quizForm?.addEventListener('hubspot:success', () => {
    showResult();
  });

  renderQuestion();
</script>
