---
interface Props {
  formId: string;
  fields?: string[];
  submitLabel?: string;
}

const {
  formId,
  fields = ['Name', 'Email'],
  submitLabel = 'Submit',
} = Astro.props;
---

<div class="hubspot-form-fallback" data-form-id={formId}>
  <!-- HUBSPOT FORM EMBED CODE HERE — replace with actual embed from HubSpot portal -->
  <form class="space-y-4" onsubmit="event.preventDefault()">
    {
      fields.map((field) => (
        <div>
          <label class="mb-1 block text-sm text-muted" for={`${formId}-${field}`}>
            {field}
          </label>
          {field === 'Message' || field.includes('challenge') ? (
            <textarea
              id={`${formId}-${field}`}
              name={field}
              rows={4}
              class="w-full rounded border border-white/10 bg-pearl px-4 py-2 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none"
            />
          ) : (
            <input
              type={field === 'Email' ? 'email' : 'text'}
              id={`${formId}-${field}`}
              name={field}
              class="w-full rounded border border-white/10 bg-pearl px-4 py-2 text-sm text-white placeholder:text-muted focus:border-aquamarine focus:outline-none"
            />
          )}
        </div>
      ))
    }
    <button
      type="submit"
      class="rounded bg-aquamarine px-6 py-3 text-sm font-semibold text-pearl transition-colors hover:bg-aquamarine/90"
    >
      {submitLabel}
    </button>
  </form>
</div>
