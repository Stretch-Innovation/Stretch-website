---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  sectionNumber?: string;
  align?: 'left' | 'center';
  variant?: 'default' | 'bunting';
}

const {
  eyebrow,
  title,
  description,
  sectionNumber,
  align = 'left',
  variant = 'default',
} = Astro.props;
---

<section
  class:list={[
    'relative overflow-hidden py-14 md:py-20 diagonal-bottom',
    variant === 'bunting' ? 'bg-bunting' : 'bg-pearl',
  ]}
>
  <div class="absolute inset-0 grid-pattern opacity-50" aria-hidden="true" />
  {
    sectionNumber && (
      <span class="section-number" aria-hidden="true">
        {sectionNumber}
      </span>
    )
  }
  <div class="relative mx-auto max-w-7xl px-4">
    <div class:list={['reveal max-w-3xl', align === 'center' && 'mx-auto text-center']}>
      {eyebrow && (
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-aquamarine">{eyebrow}</p>
      )}
      <h1 class="font-display mt-4 text-3xl font-bold leading-tight tracking-tight md:text-5xl">
        {title}
      </h1>
      {description && <p class="mt-5 text-base leading-relaxed text-muted md:text-lg">{description}</p>}
      <slot />
    </div>
  </div>
</section>
