---
interface Props {
  name: string;
  bottleneck: string;
  description: string;
  bullets?: string[];
  outcome?: string;
  href: string;
  compact?: boolean;
  delay?: number;
}

const { name, bottleneck, description, bullets, outcome, href, compact = false, delay = 0 } =
  Astro.props;
---

<a
  href={href}
  class:list={[
    'service-card-border group flex h-full flex-col rounded-lg border border-white/10 bg-cod-gray/80 p-6 backdrop-blur-sm transition-colors hover:bg-cod-gray',
    delay > 0 && `reveal reveal-delay-${delay}`,
  ]}
>
  <span class="text-xs font-semibold uppercase tracking-[0.15em] text-indigo">
    Solve: {bottleneck}
  </span>
  <h3 class="font-display mt-3 text-xl font-bold transition-colors group-hover:text-aquamarine">{name}</h3>
  <p class="mt-2 text-sm leading-relaxed text-muted">{description}</p>
  {
    bullets && !compact && (
      <ul class="mt-4 flex-1 space-y-2">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-2 text-sm text-white/80">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-aquamarine" />
            {bullet}
          </li>
        ))}
      </ul>
    )
  }
  {outcome && <p class="mt-4 text-sm font-medium text-aquamarine">{outcome}</p>}
  <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-aquamarine">
    Learn more
    <span class="transition-transform group-hover:translate-x-1">→</span>
  </span>
</a>
