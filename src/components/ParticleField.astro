---
const particles = [
  { type: 'square', w: 12, h: 12, left: '8%', delay: 0, duration: 22 },
  { type: 'ring', w: 24, h: 24, left: '18%', delay: 4, duration: 28 },
  { type: 'diamond', w: 8, h: 8, left: '32%', delay: 2, duration: 20 },
  { type: 'square', w: 16, h: 16, left: '45%', delay: 7, duration: 25 },
  { type: 'ring', w: 32, h: 32, left: '58%', delay: 1, duration: 30 },
  { type: 'diamond', w: 10, h: 10, left: '72%', delay: 5, duration: 18 },
  { type: 'square', w: 14, h: 14, left: '85%', delay: 3, duration: 24 },
  { type: 'ring', w: 20, h: 20, left: '92%', delay: 8, duration: 26 },
  { type: 'diamond', w: 6, h: 6, left: '25%', delay: 6, duration: 19 },
  { type: 'square', w: 10, h: 10, left: '65%', delay: 9, duration: 21 },
];
---

<div class="particle-field" aria-hidden="true">
  {
    particles.map((p) => (
      <div
        class:list={['particle', `particle--${p.type}`]}
        style={`width:${p.w}px;height:${p.h}px;left:${p.left};animation-duration:${p.duration}s;animation-delay:${p.delay}s;`}
      />
    ))
  }
</div>
