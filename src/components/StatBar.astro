---
interface Stat {
  value: string;
  label: string;
  countUp?: boolean;
}

interface Props {
  stats: Stat[];
  large?: boolean;
}

const { stats, large = true } = Astro.props;
---

<section class="relative overflow-hidden bg-cod-gray diagonal-both py-16 md:py-20">
  <div class="absolute inset-0 grid-pattern opacity-30" aria-hidden="true" />
  <div class="relative mx-auto grid max-w-6xl grid-cols-2 gap-8 px-4 md:grid-cols-4 md:gap-12">
    {
      stats.map((stat, i) => (
        <div class={`reveal reveal-delay-${i + 1} text-center`}>
          {
            large && stat.countUp !== false && /\d/.test(stat.value) ? (
              <div class="stat-value" data-count={stat.value}>
                0
              </div>
            ) : (
              <div class="stat-value">{stat.value}</div>
            )
          }
          <div class="mt-3 text-sm font-medium uppercase tracking-wider text-muted">
            {stat.label}
          </div>
        </div>
      ))
    }
  </div>
</section>
