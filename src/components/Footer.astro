---
import Wordmark from './stretch/Wordmark.astro';
import { CONTACT } from '../data/contact';

const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/cases', label: 'Cases' },
  { href: '/insights', label: 'Insights' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-white/10 bg-cod-gray">
  <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <a href="/" class="text-white" aria-label="Stretch Innovation home">
          <Wordmark height={32} />
        </a>
        <p class="mt-4 text-sm text-muted">
          Building predictable Growth Engines for ambitious companies.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide">Navigation</h3>
        <ul class="mt-4 space-y-2">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-muted hover:text-aquamarine">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide">Contact</h3>
        <ul class="mt-4 space-y-2 text-sm text-muted">
          <li>{CONTACT.addressLine}</li>
          <li>{CONTACT.vat}</li>
          <li>
            <a href={`mailto:${CONTACT.email}`} class="hover:text-aquamarine">
              {CONTACT.email}
            </a>
          </li>
          <li>
            <a
              href={CONTACT.linkedIn}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-aquamarine"
            >
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8 text-center text-xs text-muted">
      © {new Date().getFullYear()} Stretch Innovation. All rights reserved.
    </div>
  </div>
</footer>
