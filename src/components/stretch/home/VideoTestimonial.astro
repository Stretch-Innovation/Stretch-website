---
import Reveal from '../Reveal.astro';

interface Props {
  company: string;
  videoId: string;
}

const { company, videoId } = Astro.props;
const embedSrc = `https://www.youtube-nocookie.com/embed/${videoId}?rel=0&modestbranding=1`;
---

<section style="padding: var(--section-gap) var(--gutter);">
  <div style="max-width: var(--container-max); margin: 0 auto; text-align: center;">
    <Reveal>
      <span class="ds-eyebrow">
        <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
        In their own words
      </span>
      <h2 style="font-size: var(--text-display-3); margin-top: var(--space-3); letter-spacing: -0.02em;">{company}</h2>
    </Reveal>
    <Reveal delay={80}>
      <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; max-width: 800px; margin: var(--space-6) auto 0;">
        <iframe
          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
          src={embedSrc}
          title={`${company} video testimonial`}
          frameborder="0"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        />
      </div>
    </Reveal>
  </div>
</section>
