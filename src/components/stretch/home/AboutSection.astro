---
import Reveal from '../Reveal.astro';
import Icon from '../Icon.astro';
---

<section id="about" style="padding: var(--section-gap) var(--gutter); scroll-margin-top: var(--header-height);">
  <div class="about-grid" style="max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); align-items: center;">
    <Reveal>
      <span class="ds-eyebrow">
        <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
        Who we are
      </span>
      <h2 style="font-size: var(--text-display-3); margin-top: var(--space-3); max-width: 18ch;">A growth team that builds, not just advises</h2>
      <p style="margin-top: var(--space-4); color: var(--text-secondary); font-size: var(--text-lg); line-height: 1.65;">
        We're 36 strategists, operators and builders working out of Ghent. We don't hand you a deck and walk away — we engineer the channels, messaging and tooling into one connected system your team keeps running.
      </p>
      <div style="display: flex; gap: var(--space-7); margin-top: var(--space-6); flex-wrap: wrap;">
        <div style="display: flex; flex-direction: column; gap: 0.25rem; text-align: center;">
          <div style="font-family: var(--font-display); font-weight: 800; font-size: clamp(2.5rem,1.6rem + 3vw,3.5rem); line-height: 0.95;">
            <span style="color: var(--aquamarine);">+</span>120
          </div>
          <div style="font-size: 0.875rem; color: var(--text-muted);">Clients served</div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.25rem; text-align: center;">
          <div style="font-family: var(--font-display); font-weight: 800; font-size: clamp(2.5rem,1.6rem + 3vw,3.5rem); line-height: 0.95;">36</div>
          <div style="font-size: 0.875rem; color: var(--text-muted);">Colleagues</div>
        </div>
      </div>
      <div style="margin-top: var(--space-6);">
        <a href="/about" class="ds-btn ds-btn--outline ds-btn--md">
          Meet the team
          <Icon name="arrowRight" size={16} />
        </a>
      </div>
    </Reveal>
    <Reveal delay={120}>
      <div style="position: relative; border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--border-default); box-shadow: var(--shadow-lg);">
        <img src="/assets/team-group.jpeg" alt="The Stretch team in the Ghent office, under the neon Stretch sign" style="width: 100%; height: 100%; object-fit: cover; display: block; aspect-ratio: 4 / 3;" loading="lazy" />
        <div aria-hidden="true" style="position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(6,9,29,0.55));"></div>
      </div>
    </Reveal>
  </div>
</section>
