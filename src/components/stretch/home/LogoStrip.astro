---
import { CLIENT_LOGOS } from '../../../data/clients-logos';
---

<section style="padding: var(--space-8) var(--gutter); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); background: var(--surface-sunken);">
  <div style="max-width: var(--container-max); margin: 0 auto; text-align: center;">
    <div style="font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--space-7);">
      Trusted by growth teams scaling across Europe
    </div>
    <div style="display: flex; gap: var(--space-6) clamp(2rem, 4.5vw, 4rem); justify-content: center; flex-wrap: wrap; align-items: center;">
      {
        CLIENT_LOGOS.map((l) => (
          <img src={l.src} alt={l.alt} title={l.alt} class="client-logo" style={`height: 55px; width: auto; object-fit: contain;`} loading="lazy" />
        ))
      }
    </div>
  </div>
</section>
