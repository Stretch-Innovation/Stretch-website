---
import StretchLayout from '../../layouts/StretchLayout.astro';

interface Props {
  title: string;
  lastUpdated: string;
  seoTitle: string;
  seoDescription: string;
}

const { title, lastUpdated, seoTitle, seoDescription } = Astro.props;
---

<StretchLayout title={seoTitle} description={seoDescription}>
  <section class="legal-hero">
    <div class="legal-hero__inner">
      <h1 class="legal-hero__title">{title}</h1>
      <p class="legal-hero__updated">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <section class="legal-content">
    <div class="legal-content__inner">
      <slot />
    </div>
  </section>
</StretchLayout>

<style>
  .legal-hero {
    background: #06091d;
    padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);
  }

  .legal-hero__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .legal-hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0;
  }

  .legal-hero__updated {
    margin: var(--space-4) 0 0;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .legal-content {
    background: #f8f9fb;
    padding: var(--space-9) var(--gutter) var(--section-gap);
  }

  .legal-content__inner {
    max-width: 800px;
    margin: 0 auto;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.8;
    color: #374151;
  }

  .legal-content__inner :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: #06091d;
    margin: var(--space-8) 0 var(--space-3);
  }

  .legal-content__inner :global(h2:first-child) {
    margin-top: 0;
  }

  .legal-content__inner :global(p) {
    margin: 0 0 var(--space-4);
  }

  .legal-content__inner :global(ul) {
    margin: 0 0 var(--space-4);
    padding-left: 1.25rem;
  }

  .legal-content__inner :global(li) {
    margin-bottom: 0.5rem;
  }

  .legal-content__inner :global(li:last-child) {
    margin-bottom: 0;
  }

  .legal-content__inner :global(a) {
    color: #06091d;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-content__inner :global(a:hover) {
    color: #25db99;
  }
</style>
