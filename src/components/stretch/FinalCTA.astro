---
import Reveal from './Reveal.astro';
import Lines from './Lines.astro';
import Icon from './Icon.astro';
---

<section id="contact" style="padding: var(--section-gap) var(--gutter); scroll-margin-top: var(--header-height);">
  <Reveal>
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <div style="position: relative; overflow: hidden; border-radius: var(--radius-2xl); border: 1px solid rgba(37, 219, 153,0.25); background: linear-gradient(180deg, var(--surface-raised), var(--surface-sunken)); padding: var(--space-9) var(--gutter); text-align: center; box-shadow: var(--glow-aqua);">
        <div aria-hidden="true" style="position: absolute; bottom: -45%; left: 50%; transform: translateX(-50%); width: 760px; height: 540px; background: radial-gradient(ellipse at center, rgba(37, 219, 153,0.20), transparent 65%); pointer-events: none;"></div>
        <div style="position: relative;">
          <div style="display: inline-flex; justify-content: center; margin-bottom: var(--space-5); color: var(--aquamarine);">
            <Lines width={40} gap={6} h={3} accent opacity={0.4} />
          </div>
          <h2 style="font-size: var(--text-display-2); letter-spacing: -0.03em; max-width: 18ch; margin: 0 auto;">Ready to build your growth engine?</h2>
          <p style="margin: var(--space-4) auto 0; max-width: 48ch; color: var(--text-secondary); font-size: var(--text-lg); line-height: 1.6;">
            Book a free growth audit. We'll pinpoint your bottleneck and map the fastest path to predictable pipeline.
          </p>
          <div style="margin-top: var(--space-6); display: flex; gap: 0.875rem; justify-content: center; flex-wrap: wrap;">
            <a href="/contact" class="ds-btn ds-btn--primary ds-btn--lg">
              Identify your bottleneck
              <Icon name="arrowRight" size={18} />
            </a>
            <a href="/cases" class="ds-btn ds-btn--ghost ds-btn--lg">See the results</a>
          </div>
          <div style="margin-top: var(--space-6); display: flex; gap: var(--space-6); justify-content: center; flex-wrap: wrap; color: var(--text-muted); font-size: 0.875rem;">
            <span style="display: inline-flex; align-items: center; gap: 0.5rem;"><Icon name="check" size={15} style="color: var(--aquamarine);" /> Free 45-min audit</span>
            <span style="display: inline-flex; align-items: center; gap: 0.5rem;"><Icon name="check" size={15} style="color: var(--aquamarine);" /> No commitment</span>
            <span style="display: inline-flex; align-items: center; gap: 0.5rem;"><Icon name="check" size={15} style="color: var(--aquamarine);" /> A concrete next step</span>
          </div>
        </div>
      </div>
    </div>
  </Reveal>
</section>
