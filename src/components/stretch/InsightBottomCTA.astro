---
import Reveal from './Reveal.astro';
import Icon from './Icon.astro';
---

<section class="case-bottom-cta" style="padding: 0 var(--gutter) var(--section-gap);">
  <Reveal>
    <div class="case-bottom-cta__inner">
      <h2 class="case-bottom-cta__title">Want to apply this to your business?</h2>
      <a href="/contact" class="ds-btn ds-btn--primary ds-btn--lg">
        Speak to a growth engineer
        <Icon name="arrowRight" size={18} />
      </a>
    </div>
  </Reveal>
</section>
