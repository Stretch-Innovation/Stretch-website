---
import SectorTag from './SectorTag.astro';

interface Props {
  slug: string;
  title: string;
  category: string;
  intro: string;
  date: Date;
}

const { slug, title, category, intro, date } = Astro.props;
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/insights/${slug}`}
  class="group flex h-full flex-col rounded-lg border border-white/10 bg-cod-gray p-6 transition-colors hover:border-aquamarine/40"
>
  <div class="mb-3 flex items-center justify-between gap-2">
    <SectorTag label={category} variant="service" />
    <time class="text-xs text-muted" datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="text-lg font-bold group-hover:text-aquamarine md:text-xl">{title}</h3>
  <p class="mt-3 flex-1 text-sm text-muted">{intro}</p>
  <span class="mt-4 text-sm font-medium text-aquamarine">Read insight →</span>
</a>
