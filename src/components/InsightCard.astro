---
import SectorTag from './SectorTag.astro';

interface Props {
  slug: string;
  title: string;
  category: string;
  intro: string;
  date: Date;
  coverImage?: string;
}

const { slug, title, category, intro, date, coverImage } = Astro.props;
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/insights/${slug}`}
  class="case-card-glow group flex h-full flex-col overflow-hidden rounded-xl border border-white/10 bg-cod-gray"
>
  {
    coverImage ? (
      <div class="relative aspect-[16/9] overflow-hidden">
        <img
          src={coverImage}
          alt=""
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-cod-gray via-cod-gray/30 to-transparent" />
      </div>
    ) : (
      <div class="relative aspect-[16/9] bg-bunting">
        <div class="absolute inset-0 grid-pattern-dense opacity-40" />
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-center justify-between gap-2">
      <SectorTag label={category} variant="service" />
      <time class="text-xs text-muted" datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h3 class="font-display text-lg font-bold group-hover:text-aquamarine md:text-xl">{title}</h3>
    <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{intro}</p>
    <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-aquamarine">
      Read insight
      <span class="transition-transform group-hover:translate-x-1">→</span>
    </span>
  </div>
</a>
