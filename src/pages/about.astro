---
import StretchLayout from '../layouts/StretchLayout.astro';
import Reveal from '../components/stretch/Reveal.astro';
import Icon from '../components/stretch/Icon.astro';
import FinalCTA from '../components/stretch/FinalCTA.astro';
import VideoTestimonial from '../components/stretch/home/VideoTestimonial.astro';
import { TEAM, initials } from '../data/team';
---

<StretchLayout title="About — Stretch Innovation" description="Meet the team behind Stretch Innovation.">
  <section style="position: relative; overflow: hidden; padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);">
    <div style="position: relative; max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>Who we are</span>
        <h1 style="font-family: var(--font-display); font-weight: 800; font-size: var(--text-display-1); margin-top: var(--space-4); max-width: 16ch;">
          The team you call when growth needs <span style="color: var(--aquamarine);">doing</span>.
        </h1>
        <p style="margin-top: var(--space-5); max-width: 62ch; font-size: var(--text-lg); line-height: 1.65; color: var(--text-secondary);">
          Stretch is a growth partner for scale-ups and enterprise. We're strategists, operators and builders who treat growth as something you engineer — not something you hope for.
        </p>
      </Reveal>
    </div>
  </section>

  <section style="padding: var(--space-7) var(--gutter); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); background: var(--surface-sunken);">
    <Reveal>
      <div style="max-width: var(--container-max); margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: clamp(2rem, 6vw, 5rem); flex-wrap: wrap;">
        <div style="text-align: center;"><div style="font-family: var(--font-display); font-weight: 800; font-size: 3rem; color: var(--aquamarine);">+120</div><div style="color: var(--text-muted);">Happy clients</div></div>
        <div style="text-align: center;"><div style="font-family: var(--font-display); font-weight: 800; font-size: 3rem;">32</div><div style="color: var(--text-muted);">Colleagues</div></div>
        <div style="text-align: center;"><div style="font-family: var(--font-display); font-weight: 800; font-size: 3rem;">5</div><div style="color: var(--text-muted);">Services</div></div>
      </div>
    </Reveal>
  </section>

  <section style="padding: var(--section-gap) var(--gutter);">
    <Reveal>
      <div style="max-width: var(--container-wide); margin: 0 auto; border-radius: var(--radius-2xl); overflow: hidden; border: 1px solid var(--border-default);">
        <img src="/assets/team-group.jpeg" alt="The Stretch team together in the office" style="width: 100%; aspect-ratio: 16 / 7; object-fit: cover; object-position: center 35%; display: block;" loading="lazy" />
      </div>
    </Reveal>
  </section>

  <VideoTestimonial company="Brouwerij Van Steenberge" videoId="SFsgZQyH-h8" />

  <section style="padding: 0 var(--gutter) var(--section-gap);">
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <h2 style="font-size: var(--text-display-3); margin-bottom: var(--space-7);">The team</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-4);">
        {
          TEAM.map((member, i) => (
            <Reveal delay={(i % 4) * 60}>
              <div class="team-card" style="padding: var(--space-5); border-radius: var(--radius-card); border: 1px solid var(--border-subtle); background: var(--surface-raised); transition: all var(--dur-base) var(--ease-out);">
                <div style="width: 56px; height: 56px; border-radius: var(--radius-md); background: rgba(159,255,220,0.1); border: 1px solid var(--border-default); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; color: var(--aquamarine);">
                  {initials(member.name)}
                </div>
                <div style="margin-top: var(--space-4); font-weight: 600;">{member.name}</div>
                <div style="margin-top: 0.25rem; font-size: 0.875rem; color: var(--text-muted);">{member.role}</div>
              </div>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCTA />
</StretchLayout>
