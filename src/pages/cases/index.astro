---
import StretchLayout from '../../layouts/StretchLayout.astro';
import Reveal from '../../components/stretch/Reveal.astro';
import HomeCaseCard from '../../components/stretch/home/HomeCaseCard.astro';
import FinalCTA from '../../components/stretch/FinalCTA.astro';
import { CASE_DATA } from '../../data/cases';
---

<StretchLayout title="Cases | Stretch Innovation" description="Real results from Growth Engines we've built.">
  <section style="position: relative; overflow: hidden; padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);">
    <div aria-hidden="true" style="position: absolute; top: -20%; left: 50%; transform: translateX(-50%); width: min(1000px, 96vw); height: 600px; background: radial-gradient(ellipse at center, rgba(95,107,211,0.24), transparent 66%); pointer-events: none;"></div>
    <div style="position: relative; max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>Our work</span>
      </Reveal>
      <Reveal delay={80} tag="h1" style="font-family: var(--font-display); font-weight: 800; font-size: var(--text-display-1); line-height: 1.02; letter-spacing: -0.04em; margin-top: var(--space-4); max-width: 16ch;">
        Proof, not promises<span style="color: var(--aquamarine);">.</span>
      </Reveal>
      <Reveal delay={160} tag="p" style="margin-top: var(--space-5); max-width: 56ch; font-size: var(--text-lg); line-height: 1.6; color: var(--text-secondary);">
        Every engagement starts with a bottleneck and ends with a system that keeps running.
      </Reveal>
    </div>
  </section>

  <section style="padding: 0 var(--gutter) var(--section-gap);">
    <div class="grid-3" style="max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4);">
      {CASE_DATA.map((c, i) => (
        <Reveal delay={i * 80}>
          <HomeCaseCard c={c} />
        </Reveal>
      ))}
    </div>
  </section>

  <FinalCTA />
</StretchLayout>
