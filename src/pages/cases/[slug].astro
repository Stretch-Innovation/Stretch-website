---
import StretchLayout from '../../layouts/StretchLayout.astro';
import Reveal from '../../components/stretch/Reveal.astro';
import Icon from '../../components/stretch/Icon.astro';
import HomeCaseCard from '../../components/stretch/home/HomeCaseCard.astro';
import CaseGatedDownload from '../../components/stretch/CaseGatedDownload.astro';
import CaseBottomCTA from '../../components/stretch/CaseBottomCTA.astro';
import QuoteCard from '../../components/stretch/QuoteCard.astro';
import { CASE_DATA, getCase } from '../../data/cases';

export function getStaticPaths() {
  return CASE_DATA.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const c = getCase(slug!);
const others = CASE_DATA.filter((x) => x.slug !== slug).slice(0, 3);
---

<StretchLayout title={`${c.client} — ${c.title} · Stretch Innovation`} description={c.teaser}>
  <section style="position: relative; overflow: hidden; padding: calc(var(--header-height) + var(--space-7)) var(--gutter) var(--space-8);">
    <div style="position: relative; max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <a href="/cases" style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; font-weight: 500; color: var(--text-muted); text-decoration: none;">
          <Icon name="arrowRight" size={15} class="icon-back" /> All cases
        </a>
      </Reveal>
      <Reveal delay={60}>
        <span class="ds-eyebrow" style="margin-top: var(--space-5); display: inline-flex;">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          Case · {c.sector}
        </span>
        {c.services.map((sv) => <span class="ds-badge ds-badge--indigo" style="margin-left: 0.5rem;">{sv}</span>)}
      </Reveal>
      <Reveal delay={100} tag="h1" style="font-family: var(--font-display); font-weight: 800; font-size: var(--text-display-2); line-height: 1.04; letter-spacing: -0.035em; margin-top: var(--space-4); max-width: 20ch;">
        {c.client}<span style="color: var(--aquamarine);">.</span>
      </Reveal>
      <Reveal delay={140} tag="p" style="margin-top: var(--space-4); max-width: 60ch; font-size: var(--text-lg); line-height: 1.65; color: var(--text-secondary);">{c.intro}</Reveal>
      <Reveal delay={200}>
        <div style="margin-top: var(--space-7); border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--border-default); box-shadow: var(--shadow-lg);">
          <img src={`/assets/cases/${c.hero}`} alt={c.heroAlt} style="width: 100%; aspect-ratio: 21 / 9; object-fit: cover; display: block;" loading="lazy" />
        </div>
      </Reveal>
    </div>
  </section>

  <section style="padding: var(--section-gap) var(--gutter); border-top: 1px solid var(--border-subtle); background: var(--surface-sunken);">
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>The results</span>
        <h2 style="font-size: var(--text-display-3); margin-top: var(--space-3);">What the engine delivered</h2>
      </Reveal>
      <div class="case-stats" style="margin-top: var(--space-7); display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4);">
        {c.stats.map((s, i) => (
          <Reveal delay={i * 80}>
            <div style="padding: var(--space-6); border-radius: var(--radius-card); border: 1px solid var(--border-subtle); background: var(--surface-raised);">
              <div style="font-family: var(--font-display); font-weight: 800; font-size: clamp(2.25rem,1.6rem + 1.7vw,2.9rem); line-height: 1;">
                {s.prefix && <span style="color: var(--aquamarine);">{s.prefix}</span>}{s.value}{s.suffix && <span style="color: var(--aquamarine); font-size: 0.6em;">{s.suffix}</span>}
              </div>
              <div style="margin-top: var(--space-4); color: var(--text-secondary); font-size: 0.9375rem;">{s.label}</div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section style="padding: var(--section-gap) var(--gutter);">
    <div class="case-body" style="max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: 1fr 280px; gap: var(--space-8);">
      <div>
        <Reveal><h2 style="font-size: var(--text-h3);">The challenge</h2><p style="margin-top: var(--space-4); color: var(--text-secondary); line-height: 1.65;">{c.challenge}</p></Reveal>
        <Reveal delay={80}><h2 style="font-size: var(--text-h3); margin-top: var(--space-7);">Our approach</h2><ul style="margin-top: var(--space-4); color: var(--text-secondary); line-height: 1.65; padding-left: 1.25rem;">{c.approach.map((a) => <li style="margin-bottom: 0.5rem;">{a}</li>)}</ul></Reveal>
        <Reveal delay={120}><h2 style="font-size: var(--text-h3); margin-top: var(--space-7);">The result</h2><p style="margin-top: var(--space-4); color: var(--text-secondary); line-height: 1.65;">{c.result}</p></Reveal>
      </div>
      <aside class="case-rail" style="position: sticky; top: calc(var(--header-height) + var(--space-4)); align-self: start;">
        <div style="padding: var(--space-5); border-radius: var(--radius-card); border: 1px solid var(--border-subtle); background: var(--surface-raised);">
          <div style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted);">Headline result</div>
          <div style="margin-top: var(--space-3); font-family: var(--font-display); font-weight: 800; font-size: var(--text-h2); color: var(--aquamarine);">{c.title}</div>
        </div>
      </aside>
    </div>
  </section>

  {'quote' in c && c.quote && (
    <section style="padding: 0 var(--gutter) var(--section-gap);">
      <div style="max-width: var(--container-max); margin: 0 auto;">
        <Reveal>
          <QuoteCard quote={c.quote.text} attribution={c.quote.attribution} />
        </Reveal>
      </div>
    </section>
  )}

  {'testimonialVideoId' in c && c.testimonialVideoId && (
    <section style="padding: 0 var(--gutter) var(--section-gap);">
      <div style="max-width: var(--container-max); margin: 0 auto;">
        <Reveal>
          <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>In their own words</span>
        </Reveal>
        <Reveal delay={80}>
          <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 12px; margin-top: var(--space-5); border: 1px solid var(--border-subtle);">
            <iframe
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
              src={`https://www.youtube-nocookie.com/embed/${c.testimonialVideoId}?rel=0&modestbranding=1`}
              title={`${c.client} video testimonial`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            />
          </div>
        </Reveal>
      </div>
    </section>
  )}

  <CaseGatedDownload c={c} />
  <CaseBottomCTA />

  <section style="padding: var(--section-gap) var(--gutter); border-top: 1px solid var(--border-subtle); background: var(--surface-sunken);">
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <h2 style="font-size: var(--text-display-3);">More engines we've built</h2>
      <div class="more-grid" style="margin-top: var(--space-7); display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4);">
        {others.map((o) => <HomeCaseCard c={o} />)}
      </div>
    </div>
  </section>
</StretchLayout>
