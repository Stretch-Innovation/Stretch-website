---
import StretchLayout from '../layouts/StretchLayout.astro';
import Reveal from '../components/stretch/Reveal.astro';
import Icon from '../components/stretch/Icon.astro';
import { CORE_VALUES } from '../data/core-values';
import { getTeamPhoto } from '../data/team';
import { fetchJobs, getJobApplyUrl, getJobTeam } from '../lib/jobs';

const jobs = await fetchJobs();
const stijnPhoto = getTeamPhoto('stijn-van-daele');
---

<StretchLayout
  title="Jobs | Stretch Innovation"
  description="Join Stretch Innovation in Antwerp. Build Growth Engines that land. Explore open roles or send a spontaneous application."
>
  <section class="jobs-section jobs-section--dark jobs-hero">
    <div class="jobs-section__inner">
      <Reveal>
        <span class="ds-eyebrow">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          Join the team
        </span>
        <h1 class="jobs-hero__title">
          Build things that actually <span class="jobs-accent">land</span>.
        </h1>
        <p class="jobs-hero__subtitle">
          We're looking for curious, hands-on people who want to own their work and see it make an impact.
        </p>
      </Reveal>
    </div>
  </section>

  <section class="jobs-section jobs-section--dark jobs-quote-section">
    <div class="jobs-section__inner">
      <Reveal>
        <blockquote class="jobs-quote">
          <p class="jobs-quote__text">
            "At Stretch, we don't hand clients a deck and walk away. We build the engine, then we run it with them. That takes people who are curious, hands-on, and hungry to see their work actually land. We're 32 people based in Antwerp. If you want to own your work and grow fast, read on."
          </p>
          <footer class="jobs-quote__footer">
            <div class="jobs-quote__attribution">
              {
                stijnPhoto && (
                  <img
                    src={stijnPhoto}
                    alt="Stijn van Daele"
                    class="jobs-quote__photo"
                    loading="lazy"
                    decoding="async"
                  />
                )
              }
              <div>
                <p class="jobs-quote__name">Stijn van Daele</p>
                <p class="jobs-quote__role">Founder &amp; CEO, Stretch Innovation</p>
              </div>
            </div>
          </footer>
        </blockquote>
      </Reveal>
    </div>
  </section>

  <section class="jobs-section jobs-section--light jobs-roles-section">
    <div class="jobs-section__inner">
      <Reveal>
        <span class="ds-eyebrow jobs-eyebrow--light">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          Current openings
        </span>
        <h2 class="jobs-section__title">Open roles</h2>
        <p class="jobs-section__intro">
          Find the role that fits, or reach out anyway if you think you'd be a great match.
        </p>
      </Reveal>

      {
        jobs.length > 0 ? (
          <div class="jobs-list">
            {jobs.map((job, i) => (
              <Reveal delay={(i % 3) * 60}>
                <article class="jobs-card">
                  <div class="jobs-card__main">
                    <h3 class="jobs-card__title">{job.title}</h3>
                    <div class="jobs-card__meta">
                      {getJobTeam(job) && (
                        <span class="ds-badge ds-badge--indigo jobs-card__pill">
                          <Icon name="users" size={14} />
                          {getJobTeam(job)}
                        </span>
                      )}
                      {job.location && (
                        <span class="ds-badge ds-badge--accent jobs-card__pill">
                          <Icon name="mapPin" size={14} />
                          {job.location}
                        </span>
                      )}
                    </div>
                  </div>
                  <a
                    href={getJobApplyUrl(job)}
                    class="ds-btn ds-btn--primary ds-btn--md"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Apply
                    <Icon name="arrowRight" size={16} />
                  </a>
                </article>
              </Reveal>
            ))}
          </div>
        ) : (
          <Reveal delay={80}>
            <p class="jobs-section__intro jobs-section__intro--spaced">
              No open roles right now, but we're always looking for great people. Send us a spontaneous application.
            </p>
          </Reveal>
        )
      }
    </div>
  </section>

  <section class="jobs-section jobs-section--light jobs-values-section">
    <div class="jobs-section__inner">
      <Reveal>
        <div class="jobs-values__header">
          <span class="ds-eyebrow jobs-eyebrow--light">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            How we work
          </span>
          <h2 class="jobs-section__title">You recognize yourself in these.</h2>
          <p class="jobs-section__intro">
            These aren't wall posters. They're how we hire, collaborate, and hold each other to a high bar.
          </p>
        </div>
      </Reveal>
      <div class="jobs-values-grid">
        {
          CORE_VALUES.map((value, i) => (
            <Reveal delay={(i % 3) * 80}>
              <article class="jobs-value-card">
                <div class="jobs-value-card__top">
                  <span class="jobs-value-card__icon" aria-hidden="true">
                    <Icon name={value.icon} size={22} />
                  </span>
                  <span class="jobs-value-card__num">0{i + 1}</span>
                </div>
                <h3 class="jobs-value-card__title">{value.title}</h3>
                <p class="jobs-value-card__desc">{value.description}</p>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <section class="jobs-section jobs-section--dark jobs-life-section">
    <div class="jobs-section__inner">
      <Reveal>
        <span class="ds-eyebrow">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          Life at Stretch
        </span>
        <img
          src="/assets/team/stretch-cycling.jpeg"
          alt="Stretch team on a cycling outing"
          class="jobs-life__photo"
          loading="lazy"
          decoding="async"
        />
      </Reveal>
    </div>
  </section>

  <section class="jobs-section jobs-section--light jobs-spontaneous-section">
    <div class="jobs-section__inner">
      <Reveal>
        <div class="jobs-spontaneous">
          <h2 class="jobs-spontaneous__title">Don't see your role?</h2>
          <p class="jobs-spontaneous__text">
            We're always interested in meeting exceptional people. Send us your story.
          </p>
          <a href="/contact" class="jobs-spontaneous__cta">
            Send a spontaneous application
            <Icon name="arrowRight" size={18} />
          </a>
        </div>
      </Reveal>
    </div>
  </section>
</StretchLayout>

<style>
  .jobs-section {
    padding: var(--section-gap) var(--gutter);
  }

  .jobs-section--dark {
    background: #06091d;
    color: #ffffff;
  }

  .jobs-section--light {
    background: #f8f9fb;
    color: #06091d;
  }

  .jobs-section__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .jobs-hero {
    padding-top: calc(var(--header-height) + var(--space-8));
    padding-bottom: var(--space-8);
  }

  .jobs-hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-1);
    margin: var(--space-4) 0 0;
    max-width: 18ch;
    line-height: 1.04;
    color: #ffffff;
  }

  .jobs-accent {
    color: #25db99;
  }

  .jobs-hero__subtitle {
    margin: var(--space-5) 0 0;
    max-width: 52ch;
    font-size: var(--text-lg);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.78);
  }

  .jobs-quote-section {
    padding-top: 0;
  }

  .jobs-quote {
    margin: 0;
    padding: var(--space-7);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
  }

  .jobs-quote__text {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
  }

  .jobs-quote__footer {
    margin-top: var(--space-5);
  }

  .jobs-quote__attribution {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
  }

  .jobs-quote__photo {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
  }

  .jobs-quote__name {
    font-weight: 600;
    color: #ffffff;
    margin: 0;
  }

  .jobs-quote__role {
    font-size: 0.875rem;
    color: #8892a4;
    margin: 0;
  }

  .jobs-eyebrow--light {
    color: #25db99;
  }

  .jobs-section__title {
    font-family: var(--font-display);
    font-size: var(--text-display-3);
    font-weight: 800;
    margin: var(--space-3) 0 0;
    color: #06091d;
    letter-spacing: -0.02em;
  }

  .jobs-section__intro {
    margin: var(--space-4) 0 0;
    max-width: 48ch;
    color: #6b7280;
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .jobs-section__intro--spaced {
    margin-top: var(--space-6);
    max-width: 52ch;
  }

  .jobs-list {
    margin-top: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .jobs-card {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6);
    border-radius: 12px;
    border: none;
    background: #ffffff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition:
      transform var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }

  .jobs-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .jobs-card__main {
    min-width: 0;
    flex: 1 1 16rem;
  }

  .jobs-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    margin: 0;
    color: #06091d;
  }

  .jobs-card__meta {
    margin-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .jobs-card__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .jobs-values__header {
    max-width: 44ch;
  }

  .jobs-values-grid {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .jobs-value-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
    padding: var(--space-6);
    border-radius: 12px;
    border: none;
    background: #ffffff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition:
      transform var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }

  .jobs-value-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .jobs-value-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .jobs-value-card__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    border: 1px solid rgba(37, 219, 153, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #25db99;
    background: rgba(37, 219, 153, 0.08);
  }

  .jobs-value-card__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    color: #9ca3af;
    font-variant-numeric: tabular-nums;
  }

  .jobs-value-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h4);
    font-weight: 700;
    margin: 0;
    line-height: 1.25;
    color: #06091d;
  }

  .jobs-value-card__desc {
    margin: 0;
    color: #6b7280;
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .jobs-life__photo {
    display: block;
    width: 100%;
    max-height: 500px;
    margin-top: var(--space-5);
    border-radius: 12px;
    object-fit: cover;
  }

  .jobs-spontaneous {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto;
  }

  .jobs-spontaneous__title {
    font-family: var(--font-display);
    font-size: var(--text-display-3);
    font-weight: 800;
    margin: 0;
    color: #06091d;
    letter-spacing: -0.02em;
  }

  .jobs-spontaneous__text {
    margin: var(--space-4) auto 0;
    max-width: 42ch;
    color: #6b7280;
    font-size: var(--text-lg);
    line-height: 1.65;
  }

  .jobs-spontaneous__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-6);
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius-pill);
    background: #25db99;
    color: #06091d;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .jobs-spontaneous__cta:hover {
    opacity: 0.9;
  }

  @media (min-width: 768px) {
    .jobs-values-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .jobs-values-grid > :global(*:nth-child(7)) {
      grid-column: 2;
    }
  }
</style>
