---
import Layout from '../layouts/Layout.astro';
import HubSpotFormFallback from '../components/HubSpotFormFallback.astro';
---

<Layout title="Contact — Stretch Innovation" description="Let's talk growth. Tell us where you're stuck.">
  <section class="py-12 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h1 class="text-3xl font-bold md:text-5xl">Let's talk growth.</h1>
      <p class="mt-4 text-lg text-muted">
        Tell us where you're stuck. We'll tell you how we'd approach it.
      </p>

      <div class="mt-12 grid gap-12 md:grid-cols-2">
        <div>
          <h2 class="text-lg font-bold">Get in touch</h2>
          <ul class="mt-6 space-y-4 text-muted">
            <li>
              <a href="mailto:stijn@stretchinnovation.be" class="hover:text-aquamarine">
                stijn@stretchinnovation.be
              </a>
            </li>
            <li>
              <a href="tel:+32477986352" class="hover:text-aquamarine">+32 477 98 63 52</a>
            </li>
            <li>Desguinlei 6, 2018 Antwerpen</li>
            <li>
              <a
                href="https://www.linkedin.com/company/stretch-innovation"
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-aquamarine"
              >
                LinkedIn
              </a>
            </li>
          </ul>
        </div>

        <div>
          <!-- HUBSPOT CONTACT FORM EMBED CODE HERE -->
          <HubSpotFormFallback
            formId="contact-form"
            fields={[
              'Name',
              'Company',
              'Email',
              'Phone',
              'Message',
              "What's your biggest growth challenge right now?",
            ]}
            submitLabel="Send message"
          />
        </div>
      </div>

      <p class="mt-12 text-center text-sm text-muted">
        Or <a href="/bottleneck-quiz" class="text-aquamarine hover:underline">identify your bottleneck first →</a>
      </p>
    </div>
  </section>
</Layout>
