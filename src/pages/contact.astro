---
import StretchLayout from '../layouts/StretchLayout.astro';
import Reveal from '../components/stretch/Reveal.astro';
import Icon from '../components/stretch/Icon.astro';
import QuoteCard from '../components/stretch/QuoteCard.astro';
import { CONTACT } from '../data/contact';
import { CONTACT_TESTIMONIALS } from '../data/testimonials';
---

<StretchLayout title="Contact — Stretch Innovation" description="Book a free growth audit or get in touch with Stretch Innovation.">
  <section style="position: relative; overflow: hidden; padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-7);">
    <div style="position: relative; max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>Get in touch</span>
        <h1 style="font-family: var(--font-display); font-weight: 800; font-size: clamp(2rem, 8vw, 4rem); margin-top: var(--space-4); max-width: 18ch; line-height: 1.05;">
          Let's find your bottleneck<span style="color: var(--aquamarine);">.</span>
        </h1>
        <p style="margin-top: var(--space-5); max-width: 52ch; font-size: var(--text-lg); color: var(--text-secondary); line-height: 1.65;">
          Book a free 45-minute growth audit. We'll map your current setup, identify the constraint, and outline the fastest path to predictable pipeline.
        </p>
      </Reveal>
    </div>
  </section>

  <section style="padding: 0 var(--gutter) var(--space-6);">
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <div class="contact-quotes">
        {
          CONTACT_TESTIMONIALS.map((t, i) => (
            <Reveal delay={i * 80}>
              <QuoteCard quote={t.quote} attribution={t.attribution} compact />
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <section style="padding: 0 var(--gutter) var(--section-gap);">
    <div class="contact-grid" style="max-width: var(--container-max); margin: 0 auto; display: grid; grid-template-columns: 1fr; gap: var(--space-8);">
      <Reveal>
        <form class="contact-form" style="padding: var(--space-7); border-radius: var(--radius-xl); border: 1px solid var(--border-subtle); background: var(--surface-sunken); display: flex; flex-direction: column; gap: var(--space-4);">
          <label class="contact-field" style="display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.8125rem; color: var(--text-secondary);">
            Name
            <input type="text" name="name" placeholder="Jane Doe" style="width: 100%; box-sizing: border-box; padding: 0.75rem 0.875rem; border-radius: var(--radius-md); border: 1px solid var(--border-default); background: var(--surface-base); color: var(--text-primary); font-family: var(--font-body);" />
          </label>
          <label class="contact-field" style="display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.8125rem; color: var(--text-secondary);">
            Company email
            <input type="email" name="email" placeholder="you@company.com" style="width: 100%; box-sizing: border-box; padding: 0.75rem 0.875rem; border-radius: var(--radius-md); border: 1px solid var(--border-default); background: var(--surface-base); color: var(--text-primary); font-family: var(--font-body);" />
          </label>
          <label class="contact-field" style="display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.8125rem; color: var(--text-secondary);">
            Message
            <textarea name="message" rows="4" placeholder="Tell us about your growth challenge..." style="width: 100%; box-sizing: border-box; padding: 0.75rem 0.875rem; border-radius: var(--radius-md); border: 1px solid var(--border-default); background: var(--surface-base); color: var(--text-primary); font-family: var(--font-body); resize: vertical;"></textarea>
          </label>
          <button type="submit" class="ds-btn ds-btn--primary ds-btn--lg">Book a growth audit <Icon name="arrowRight" size={18} /></button>
        </form>
      </Reveal>
      <Reveal delay={80}>
        <div class="contact-card" style="padding: var(--space-7); border-radius: var(--radius-xl); border: 1px solid var(--border-subtle); background: var(--surface-raised);">
          <h2 style="font-size: var(--text-h3); margin: 0;">Contact details</h2>
          <div style="margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-5); color: var(--text-secondary);">
            <span style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <Icon name="mapPin" size={18} />
              <span>
                {CONTACT.street}<br />
                {CONTACT.city}<br />
                <span style="font-size: 0.8125rem; color: var(--text-muted);">{CONTACT.vat}</span>
              </span>
            </span>
            <a href={`mailto:${CONTACT.email}`} style="display: flex; align-items: center; gap: 0.75rem; color: inherit; text-decoration: none;">
              <Icon name="mail" size={18} />
              {CONTACT.email}
            </a>
            <a href={`tel:${CONTACT.phoneTel}`} style="display: flex; align-items: center; gap: 0.75rem; color: inherit; text-decoration: none;">
              <Icon name="phone" size={18} />
              {CONTACT.phone}
            </a>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <section style="padding: 0 var(--gutter) var(--section-gap);">
    <Reveal>
      <div class="contact-cta" style="max-width: var(--container-max); margin: 0 auto; border-radius: var(--radius-xl); border: 1px solid var(--border-subtle); background: var(--surface-sunken); padding: var(--space-7); text-align: center;">
        <span style="font-family: var(--font-display); font-weight: 600; font-size: var(--text-h3);">Not ready to talk yet?</span>
        <a href="/bottleneck-quiz" style="display: inline-flex; align-items: center; gap: 0.45rem; font-weight: 600; color: var(--aquamarine); text-decoration: none;">
          Identify your growth bottleneck first <Icon name="arrowRight" size={17} />
        </a>
      </div>
    </Reveal>
  </section>
</StretchLayout>

<style>
  .contact-grid,
  .contact-card,
  .contact-form {
    width: 100%;
    min-width: 0;
  }

  .contact-quotes {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .contact-quotes {
      grid-template-columns: 1fr 1fr;
    }

    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .contact-cta {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-5);
    }
  }
</style>
