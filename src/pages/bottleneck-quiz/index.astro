---
import Layout from '../../layouts/Layout.astro';
import BottleneckQuiz from '../../components/BottleneckQuiz.astro';
---

<Layout
  title="Growth Bottleneck Quiz — Stretch Innovation"
  description="Find your growth bottleneck in 2 minutes. Answer 4 questions and get a clear diagnosis."
>
  <section class="py-12 md:py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-3xl font-bold md:text-4xl">Find your growth bottleneck in 2 minutes.</h1>
      <p class="mt-4 text-lg text-muted">
        Answer 4 questions. Get a clear diagnosis and a recommended next step.
      </p>
      <div class="mt-12">
        <BottleneckQuiz />
      </div>
    </div>
  </section>
</Layout>
