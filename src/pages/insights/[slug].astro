---
import StretchLayout from '../../layouts/StretchLayout.astro';
import Reveal from '../../components/stretch/Reveal.astro';
import InsightGatedDownload from '../../components/stretch/InsightGatedDownload.astro';
import InsightBottomCTA from '../../components/stretch/InsightBottomCTA.astro';
import { INSIGHT_DATA, getInsight, formatInsightDate } from '../../data/insights';

export function getStaticPaths() {
  return INSIGHT_DATA.map((i) => ({ params: { slug: i.slug } }));
}

const { slug } = Astro.params;
const ins = getInsight(slug!);
---

<StretchLayout title={`${ins.title} — Stretch Innovation`} description={ins.excerpt}>
  <article style="padding: calc(var(--header-height) + var(--space-8)) var(--gutter) 0;">
    <div style="max-width: var(--container-prose); margin: 0 auto;">
      <Reveal>
        <span class="ds-badge ds-badge--accent">{ins.category}</span>
        <span style="margin-left: 0.75rem; font-size: 0.875rem; color: var(--text-muted);">{formatInsightDate(ins.date)}</span>
        <h1 style="font-family: var(--font-display); font-weight: 800; font-size: var(--text-display-2); margin-top: var(--space-5); line-height: 1.1;">{ins.title}</h1>
        <p style="margin-top: var(--space-4); font-size: var(--text-lg); color: var(--text-secondary); line-height: 1.65;">{ins.excerpt}</p>
      </Reveal>

      <div style="margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-5); color: var(--text-secondary); line-height: 1.7;">
        {
          ins.body.map((block) => {
            if ('lead' in block) return <p style="font-size: var(--text-lg); color: var(--text-primary);">{block.lead}</p>;
            if ('h2' in block) return <h2 style="font-family: var(--font-display); font-size: var(--text-h2); color: var(--text-primary); margin-top: var(--space-4);">{block.h2}</h2>;
            if ('p' in block) return <p>{block.p}</p>;
            if ('ul' in block) return <ul style="padding-left: 1.25rem;">{block.ul.map((li) => <li style="margin-bottom: 0.5rem;">{li}</li>)}</ul>;
            if ('fix' in block) return <p style="padding: var(--space-4); border-left: 3px solid var(--aquamarine); background: rgba(159,255,220,0.06); border-radius: var(--radius-sm); color: var(--text-primary); font-weight: 500;">{block.fix}</p>;
            return null;
          })
        }
      </div>
    </div>
  </article>

  <InsightGatedDownload ins={ins} />
  <InsightBottomCTA />
</StretchLayout>
