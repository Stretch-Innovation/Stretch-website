---
import StretchLayout from '../layouts/StretchLayout.astro';
import Reveal from '../components/stretch/Reveal.astro';
import Icon from '../components/stretch/Icon.astro';

const archetypes = [
  {
    label: 'Archetype A',
    title: 'Sales-Led Ceiling',
    headline: "You've scaled through hiring. Now it's not working.",
    traits: [
      'Historically scaled by hiring more sales reps',
      'Small marketing team added later as support',
      'Low pipeline predictability despite high activity',
      'More hires no longer create proportional growth',
    ],
    core: 'More sales hires no longer create proportional growth. You need a revenue system, not more headcount.',
    need: 'A structured revenue system that generates predictable pipeline — without depending on individual heroes.',
  },
  {
    label: 'Archetype B',
    title: 'Marketing-Heavy Chaos',
    headline: "You're spending on marketing. But nothing's clear.",
    traits: [
      'Large marketing budget, many channels active',
      'Dashboards exist but attribution is unclear',
      'Multiple disconnected initiatives running',
      'High activity, low clarity on what drives revenue',
    ],
    core: 'High activity, low clarity. Spending budget is easy — knowing what actually drives growth is hard.',
    need: 'A Growth Engine that turns marketing spend into a compounding, measurable system.',
  },
];

const modifiers = [
  {
    icon: '📈',
    title: 'PE-Backed Companies',
    description:
      'You have a clear growth mandate and board pressure to deliver top-line results. Exit valuation depends on predictable revenue engines. You need a system now.',
    tags: ['Private Equity', 'Venture Capital', 'M&A'],
  },
  {
    icon: '🌍',
    title: 'International Expansion',
    description:
      "You're entering Belgium, Netherlands, Germany, France or the UK. Ad hoc tactics fail when duplicating across borders. You need a proven go-to-market system.",
    tags: ['BE / NL', 'DACH', 'UK / FR'],
  },
  {
    icon: '🏭',
    title: 'Food & FMCG',
    description:
      'Complex channel dynamics — B2B foodservice, retail trade marketing, or D2C. Each channel needs a different growth engine.',
    tags: ['Food', 'Foodservice', 'Retail', 'Beverage'],
  },
];

const personas = ['CEO', 'CMO', 'CRO', 'Commercial Director'];

const triggers = [
  'Revenue plateau despite increased activity',
  'Doubts about marketing ROI & attribution',
  'Scaling inefficiency — headcount growing faster than revenue',
  'International growth ambition',
  'PE growth mandate or exit preparation',
];

const examples = [
  {
    title: 'PE-backed food producer expanding to Germany',
    tags: ['Sales-Led Ceiling', 'PE-Backed', 'Food', 'International'],
    description:
      "Needs a predictable system immediately to justify valuation. Can't afford to experiment — needs results fast.",
  },
  {
    title: 'Marketing-heavy SaaS expanding to the UK',
    tags: ['Marketing Chaos', 'International'],
    description: 'Needs to structure marketing spend before burning cash in an expensive new market.',
  },
];
---

<StretchLayout
  title="For Who — Stretch Innovation"
  description="Stretch works with scale-ups and enterprise companies that have hit a growth ceiling and need a structured Growth Engine."
>
  <!-- Section 1: Hero -->
  <section class="fw-hero">
    <div class="fw-container">
      <Reveal>
        <span class="ds-eyebrow">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          For Who
        </span>
        <h1 class="fw-hero__title">Built for companies serious about <span class="fw-accent">growth</span>.</h1>
        <p class="fw-hero__lead">
          We work with scale-ups and enterprise companies that have hit a growth ceiling — and need a system, not more headcount.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Section 2: Archetypes -->
  <section class="fw-section fw-section--sunken">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Who we work with
          </span>
          <h2 class="fw-section__title">Two types of companies come to us.</h2>
          <p class="fw-section__lead">Different symptoms, same root cause: no structured Growth Engine.</p>
        </div>
      </Reveal>

      <div class="fw-archetypes">
        {
          archetypes.map((item, i) => (
            <Reveal delay={i * 90}>
              <article class="fw-archetype-card">
                <span class="fw-archetype-card__label">{item.label}: {item.title}</span>
                <h3 class="fw-archetype-card__headline">{item.headline}</h3>
                <ul class="fw-checklist">
                  {item.traits.map((trait) => (
                    <li>
                      <span class="fw-checklist__icon" aria-hidden="true">
                        <Icon name="check" size={14} />
                      </span>
                      {trait}
                    </li>
                  ))}
                </ul>
                <div class="fw-callout fw-callout--core">
                  <span class="fw-callout__label">The core</span>
                  <p>{item.core}</p>
                </div>
                <div class="fw-callout fw-callout--need">
                  <span class="fw-callout__label">What they need</span>
                  <p>{item.need}</p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 3: Strategic fit modifiers -->
  <section class="fw-section">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            What makes it urgent
          </span>
          <h2 class="fw-section__title">Three situations that accelerate the need.</h2>
        </div>
      </Reveal>

      <div class="fw-modifiers">
        {
          modifiers.map((item, i) => (
            <Reveal delay={i * 80}>
              <article class="fw-modifier-card">
                <span class="fw-modifier-card__icon" aria-hidden="true">{item.icon}</span>
                <h3 class="fw-modifier-card__title">{item.title}</h3>
                <p class="fw-modifier-card__desc">{item.description}</p>
                <div class="fw-tags">
                  {item.tags.map((tag) => (
                    <span class="fw-tag">{tag}</span>
                  ))}
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 4: Decision makers -->
  <section class="fw-section fw-section--sunken">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header fw-section__header--center">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Who we talk to
          </span>
          <h2 class="fw-section__title">We work with the people who own growth.</h2>
        </div>
      </Reveal>

      <Reveal delay={80}>
        <div class="fw-personas">
          {personas.map((persona) => (
            <span class="fw-persona-pill">{persona}</span>
          ))}
        </div>
      </Reveal>

      <Reveal delay={140}>
        <div class="fw-triggers">
          <p class="fw-triggers__lead">You'll recognize these moments:</p>
          <ul class="fw-checklist fw-checklist--centered">
            {triggers.map((trigger) => (
              <li>
                <span class="fw-checklist__icon" aria-hidden="true">
                  <Icon name="check" size={14} />
                </span>
                {trigger}
              </li>
            ))}
          </ul>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 5: Examples -->
  <section class="fw-section">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Examples
          </span>
          <h2 class="fw-section__title">Sound familiar?</h2>
        </div>
      </Reveal>

      <div class="fw-examples">
        {
          examples.map((item, i) => (
            <Reveal delay={i * 90}>
              <article class="fw-example-card">
                <h3 class="fw-example-card__title">{item.title}</h3>
                <div class="fw-tags">
                  {item.tags.map((tag) => (
                    <span class="fw-tag fw-tag--accent">{tag}</span>
                  ))}
                </div>
                <p class="fw-example-card__desc">{item.description}</p>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 6: CTA -->
  <section class="fw-section fw-cta">
    <div class="fw-container">
      <Reveal>
        <div class="fw-cta__card">
          <h2 class="fw-cta__title">Does this sound like your company?</h2>
          <p class="fw-cta__lead">
            Book a free 45-minute growth audit. We'll identify your archetype and map the fastest path to predictable growth.
          </p>
          <a href="/contact" class="ds-btn ds-btn--primary ds-btn--lg">
            Identify your bottleneck
            <Icon name="arrowRight" size={18} />
          </a>
          <p class="fw-cta__note">Free 45-min audit · No commitment · A concrete next step</p>
        </div>
      </Reveal>
    </div>
  </section>
</StretchLayout>

<style>
  .fw-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .fw-accent {
    color: var(--aquamarine);
  }

  .fw-hero {
    padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);
  }

  .fw-hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-1);
    line-height: 1.05;
    margin: var(--space-4) 0 0;
    max-width: 18ch;
  }

  .fw-hero__lead {
    margin: var(--space-5) 0 0;
    max-width: 58ch;
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .fw-section {
    padding: var(--section-gap) 0;
  }

  .fw-section--sunken {
    background: var(--surface-sunken);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .fw-section__header {
    max-width: 52ch;
    margin-bottom: var(--space-7);
  }

  .fw-section__header--center {
    max-width: none;
    text-align: center;
    margin-inline: auto;
  }

  .fw-section__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-3);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: var(--space-3) 0 0;
  }

  .fw-section__lead {
    margin: var(--space-4) 0 0;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .fw-archetypes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .fw-archetype-card {
    height: 100%;
    padding: var(--space-7);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
    box-shadow: var(--shadow-inset-hairline);
  }

  .fw-archetype-card__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--aquamarine);
  }

  .fw-archetype-card__headline {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    line-height: 1.2;
    margin: var(--space-4) 0 0;
  }

  .fw-checklist {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fw-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .fw-checklist__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 219, 153, 0.12);
    color: var(--aquamarine);
    margin-top: 0.1rem;
  }

  .fw-callout {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .fw-callout--core {
    background: rgba(37, 219, 153, 0.06);
    border-color: rgba(37, 219, 153, 0.2);
  }

  .fw-callout--need {
    background: rgba(95, 107, 211, 0.08);
    border-color: rgba(95, 107, 211, 0.25);
  }

  .fw-callout__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .fw-callout p {
    margin: 0;
    color: var(--text-primary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .fw-modifiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .fw-modifier-card {
    height: 100%;
    padding: var(--space-6);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
    transition:
      border-color var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .fw-modifier-card:hover {
    border-color: rgba(37, 219, 153, 0.35);
    transform: translateY(-3px);
  }

  .fw-modifier-card__icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .fw-modifier-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    margin: var(--space-4) 0 0;
  }

  .fw-modifier-card__desc {
    margin: var(--space-3) 0 0;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .fw-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-5);
  }

  .fw-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.625rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-default);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text-muted);
  }

  .fw-tag--accent {
    color: var(--indigo-300);
    border-color: rgba(95, 107, 211, 0.35);
    background: rgba(95, 107, 211, 0.12);
  }

  .fw-personas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: var(--space-7);
  }

  .fw-persona-pill {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-pill);
    background: var(--aquamarine);
    color: #06091d;
  }

  .fw-triggers {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-6);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
  }

  .fw-triggers__lead {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h4);
    text-align: center;
  }

  .fw-checklist--centered {
    max-width: 36rem;
    margin-inline: auto;
  }

  .fw-examples {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .fw-example-card {
    height: 100%;
    padding: var(--space-6);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
  }

  .fw-example-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.25;
    margin: 0;
  }

  .fw-example-card__desc {
    margin: var(--space-4) 0 0;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .fw-cta {
    padding-bottom: var(--section-gap);
  }

  .fw-cta__card {
    text-align: center;
    padding: var(--space-9) var(--gutter);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(37, 219, 153, 0.25);
    background: linear-gradient(180deg, var(--surface-raised), var(--surface-sunken));
    box-shadow: var(--glow-aqua);
  }

  .fw-cta__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-3);
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 20ch;
    margin-inline: auto;
  }

  .fw-cta__lead {
    margin: var(--space-4) auto 0;
    max-width: 50ch;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .fw-cta__card .ds-btn {
    margin-top: var(--space-6);
  }

  .fw-cta__note {
    margin: var(--space-5) 0 0;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  @media (max-width: 1024px) {
    .fw-modifiers {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .fw-archetypes,
    .fw-examples {
      grid-template-columns: 1fr;
    }

    .fw-archetype-card,
    .fw-cta__card {
      padding: var(--space-6);
    }
  }
</style>
