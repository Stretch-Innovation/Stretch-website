---
import StretchLayout from '../layouts/StretchLayout.astro';
import Reveal from '../components/stretch/Reveal.astro';
import Icon from '../components/stretch/Icon.astro';

const archetypes = [
  {
    label: 'Archetype A',
    title: 'Sales-Led Ceiling',
    headline: "You've scaled through hiring. Now it's not working.",
    traits: [
      'Historically scaled by hiring more sales reps',
      'Small marketing team added later as support',
      'Low pipeline predictability despite high activity',
      'More hires no longer create proportional growth',
    ],
    core: 'More sales hires no longer create proportional growth. You need a revenue system, not more headcount.',
    need: 'A structured revenue system that generates predictable pipeline — without depending on individual heroes.',
  },
  {
    label: 'Archetype B',
    title: 'Marketing-Heavy Chaos',
    headline: "You're spending on marketing. But nothing's clear.",
    traits: [
      'Large marketing budget, many channels active',
      'Dashboards exist but attribution is unclear',
      'Multiple disconnected initiatives running',
      'High activity, low clarity on what drives revenue',
    ],
    core: 'High activity, low clarity. Spending budget is easy — knowing what actually drives growth is hard.',
    need: 'A Growth Engine that turns marketing spend into a compounding, measurable system.',
  },
];

const personas = ['CEO', 'CMO', 'CRO', 'Commercial Director'];

const triggers = [
  'Revenue plateau despite increased activity',
  'Doubts about marketing ROI & attribution',
  'Scaling inefficiency — headcount growing faster than revenue',
  'International growth ambition',
  'PE growth mandate or exit preparation',
];

const situations = [
  {
    headline: "You hired more sales reps. Pipeline didn't follow.",
    subtext: "Headcount grew but revenue didn't scale proportionally. The system isn't there yet.",
  },
  {
    headline: "You're spending on marketing but can't see what's working.",
    subtext: 'Dashboards full of activity metrics. Attribution is a guess. Budget keeps going out the door.',
  },
  {
    headline: "You're entering a new market and need it to work.",
    subtext: "Expanding to Germany, the UK or France. You can't afford to experiment — you need a proven system.",
  },
  {
    headline: 'Your PE investor wants predictable growth. Fast.',
    subtext: 'Exit prep or portfolio acceleration. The board needs clear metrics and top-line momentum.',
  },
  {
    headline: "Leads come in but don't convert.",
    subtext: "The funnel leaks somewhere between first interest and signed revenue. You're not sure where.",
  },
  {
    headline: 'Every quarter feels like starting over.',
    subtext: 'No compounding effect. Growth is individual, not systemic. Heroes carry the team.',
  },
  {
    headline: "You've outgrown your current agency.",
    subtext: "They execute tasks but don't think strategically. You need a partner who owns outcomes.",
  },
  {
    headline: 'You know growth is possible. You just need the engine.',
    subtext: "Product-market fit is there. The demand generation system isn't built yet.",
  },
];
---

<StretchLayout
  title="For Who — Stretch Innovation"
  description="Stretch works with scale-ups and enterprise companies that have hit a growth ceiling and need a structured Growth Engine."
>
  <!-- Section 1: Hero -->
  <section class="fw-hero">
    <div class="fw-container">
      <Reveal>
        <span class="ds-eyebrow">
          <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
          For Who
        </span>
        <h1 class="fw-hero__title">Built for companies serious about <span class="fw-accent">growth</span>.</h1>
        <p class="fw-hero__lead">
          We work with scale-ups and enterprise companies that have hit a growth ceiling — and need a system, not more headcount.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Section 2: Archetypes -->
  <section class="fw-section fw-section--sunken">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Who we work with
          </span>
          <h2 class="fw-section__title">Two types of companies come to us.</h2>
          <p class="fw-section__lead">Different symptoms, same root cause: no structured Growth Engine.</p>
        </div>
      </Reveal>

      <div class="fw-archetypes">
        {
          archetypes.map((item, i) => (
            <Reveal delay={i * 90}>
              <article class="fw-archetype-card">
                <span class="fw-archetype-card__label">{item.label}: {item.title}</span>
                <h3 class="fw-archetype-card__headline">{item.headline}</h3>
                <ul class="fw-checklist">
                  {item.traits.map((trait) => (
                    <li>
                      <span class="fw-checklist__icon" aria-hidden="true">
                        <Icon name="check" size={14} />
                      </span>
                      {trait}
                    </li>
                  ))}
                </ul>
                <div class="fw-callout fw-callout--core">
                  <span class="fw-callout__label">The core</span>
                  <p>{item.core}</p>
                </div>
                <div class="fw-callout fw-callout--need">
                  <span class="fw-callout__label">What they need</span>
                  <p>{item.need}</p>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 3: Decision makers -->
  <section class="fw-section fw-section--sunken">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header fw-section__header--center">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Who we talk to
          </span>
          <h2 class="fw-section__title">We work with the people who own growth.</h2>
        </div>
      </Reveal>

      <Reveal delay={80}>
        <div class="fw-personas">
          {personas.map((persona) => (
            <span class="fw-persona-pill">{persona}</span>
          ))}
        </div>
      </Reveal>

      <Reveal delay={140}>
        <div class="fw-triggers">
          <p class="fw-triggers__lead">You'll recognize these moments:</p>
          <ul class="fw-checklist fw-checklist--centered">
            {triggers.map((trigger) => (
              <li>
                <span class="fw-checklist__icon" aria-hidden="true">
                  <Icon name="check" size={14} />
                </span>
                {trigger}
              </li>
            ))}
          </ul>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 4: Sound familiar -->
  <section class="fw-section">
    <div class="fw-container">
      <Reveal>
        <div class="fw-section__header">
          <span class="ds-eyebrow">
            <span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Examples
          </span>
          <h2 class="fw-section__title">Sound familiar?</h2>
        </div>
      </Reveal>

      <div class="fw-situations">
        {
          situations.map((item, i) => (
            <Reveal delay={(i % 2) * 60 + Math.floor(i / 2) * 80}>
              <article class="fw-situation-card">
                <div class="fw-situation-card__headline-row">
                  <span class="fw-situation-card__icon" aria-hidden="true">
                    <Icon name="check" size={14} />
                  </span>
                  <h3 class="fw-situation-card__title">{item.headline}</h3>
                </div>
                <p class="fw-situation-card__subtext">{item.subtext}</p>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 5: CTA -->
  <section class="fw-section fw-cta">
    <div class="fw-container">
      <Reveal>
        <div class="fw-cta__card">
          <h2 class="fw-cta__title">Does this sound like your company?</h2>
          <p class="fw-cta__lead">
            Book a free 45-minute growth audit. We'll identify your archetype and map the fastest path to predictable growth.
          </p>
          <a href="/contact" class="ds-btn ds-btn--primary ds-btn--lg">
            Identify your bottleneck
            <Icon name="arrowRight" size={18} />
          </a>
          <p class="fw-cta__note">Free 45-min audit · No commitment · A concrete next step</p>
        </div>
      </Reveal>
    </div>
  </section>
</StretchLayout>

<style>
  .fw-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .fw-accent {
    color: var(--aquamarine);
  }

  .fw-hero {
    padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);
  }

  .fw-hero__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-1);
    line-height: 1.05;
    margin: var(--space-4) 0 0;
    max-width: 18ch;
  }

  .fw-hero__lead {
    margin: var(--space-5) 0 0;
    max-width: 58ch;
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .fw-section {
    padding: var(--section-gap) 0;
  }

  .fw-section--sunken {
    background: var(--surface-sunken);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .fw-section__header {
    max-width: 52ch;
    margin-bottom: var(--space-7);
  }

  .fw-section__header--center {
    max-width: none;
    text-align: center;
    margin-inline: auto;
  }

  .fw-section__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-3);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: var(--space-3) 0 0;
  }

  .fw-section__lead {
    margin: var(--space-4) 0 0;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .fw-archetypes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .fw-archetype-card {
    height: 100%;
    padding: var(--space-7);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
    box-shadow: var(--shadow-inset-hairline);
  }

  .fw-archetype-card__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--aquamarine);
  }

  .fw-archetype-card__headline {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    line-height: 1.2;
    margin: var(--space-4) 0 0;
  }

  .fw-checklist {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fw-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .fw-checklist__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 219, 153, 0.12);
    color: var(--aquamarine);
    margin-top: 0.1rem;
  }

  .fw-callout {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .fw-callout--core {
    background: rgba(37, 219, 153, 0.06);
    border-color: rgba(37, 219, 153, 0.2);
  }

  .fw-callout--need {
    background: rgba(95, 107, 211, 0.08);
    border-color: rgba(95, 107, 211, 0.25);
  }

  .fw-callout__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .fw-callout p {
    margin: 0;
    color: var(--text-primary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .fw-situations {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .fw-situation-card {
    height: 100%;
    padding: var(--space-6);
    border-radius: var(--radius-card);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #0e1330;
    transition:
      border-color var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .fw-situation-card:hover {
    border-color: rgba(37, 219, 153, 0.3);
    transform: translateY(-3px);
  }

  .fw-situation-card__headline-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .fw-situation-card__icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 219, 153, 0.12);
    color: var(--aquamarine);
    margin-top: 0.15rem;
  }

  .fw-situation-card__title {
    font-family: var(--font-display);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--aquamarine);
  }

  .fw-situation-card__subtext {
    margin: var(--space-4) 0 0 2.125rem;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .fw-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: var(--space-7);
  }

  .fw-persona-pill {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-pill);
    background: var(--aquamarine);
    color: #06091d;
  }

  .fw-triggers {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-6);
    border-radius: var(--radius-card);
    border: 1px solid var(--border-subtle);
    background: var(--surface-raised);
  }

  .fw-triggers__lead {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h4);
    text-align: center;
  }

  .fw-checklist--centered {
    max-width: 36rem;
    margin-inline: auto;
  }

  .fw-personas {
    padding-bottom: var(--section-gap);
  }

  .fw-cta__card {
    text-align: center;
    padding: var(--space-9) var(--gutter);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(37, 219, 153, 0.25);
    background: linear-gradient(180deg, var(--surface-raised), var(--surface-sunken));
    box-shadow: var(--glow-aqua);
  }

  .fw-cta__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-display-3);
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 20ch;
    margin-inline: auto;
  }

  .fw-cta__lead {
    margin: var(--space-4) auto 0;
    max-width: 50ch;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .fw-cta__card .ds-btn {
    margin-top: var(--space-6);
  }

  .fw-cta__note {
    margin: var(--space-5) 0 0;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  @media (max-width: 860px) {
    .fw-archetypes,
    .fw-situations {
      grid-template-columns: 1fr;
    }

    .fw-situation-card__subtext {
      margin-left: 0;
    }

    .fw-archetype-card,
    .fw-cta__card {
      padding: var(--space-6);
    }
  }
</style>
