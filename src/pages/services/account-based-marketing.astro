---
import StretchLayout from '../../layouts/StretchLayout.astro';
import ServicePage from '../../components/stretch/ServicePage.astro';
import { SERVICE_DATA } from '../../data/stretch-services';

const slug = 'account-based-marketing';
const service = SERVICE_DATA.find((s) => s.slug === slug)!;
---

<StretchLayout title={`${service.name} — Stretch Innovation`} description={service.short}>
  <ServicePage slug={slug} />
</StretchLayout>
