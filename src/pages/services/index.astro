---
import StretchLayout from '../../layouts/StretchLayout.astro';
import Reveal from '../../components/stretch/Reveal.astro';
import Icon from '../../components/stretch/Icon.astro';
import FinalCTA from '../../components/stretch/FinalCTA.astro';
import { SERVICE_DATA } from '../../data/stretch-services';
---

<StretchLayout title="Services | Stretch Innovation" description="Five ways we build your Growth Engine.">
  <section style="padding: calc(var(--header-height) + var(--space-8)) var(--gutter) var(--space-8);">
    <div style="max-width: var(--container-max); margin: 0 auto;">
      <Reveal>
        <span class="ds-eyebrow"><span class="ds-eyebrow-mark" aria-hidden="true"><span></span><span></span><span></span></span>Services</span>
        <h1 style="font-family: var(--font-display); font-weight: 800; font-size: var(--text-display-1); margin-top: var(--space-4); max-width: 20ch;">Five ways we build your Growth Engine.</h1>
      </Reveal>
    </div>
  </section>

  <section style="padding: 0 var(--gutter) var(--section-gap);">
    <div style="max-width: var(--container-max); margin: 0 auto; display: grid; gap: var(--space-4);">
      {
        SERVICE_DATA.map((s, i) => (
          <Reveal delay={i * 60}>
            <a href={`/services/${s.slug}`} class="hover-service-card" style="display: flex; gap: var(--space-5); padding: var(--space-6); border-radius: var(--radius-card); border: 1px solid var(--border-subtle); background: var(--surface-raised); text-decoration: none; color: inherit;">
              <span style="width: 48px; height: 48px; flex-shrink: 0; border-radius: var(--radius-md); border: 1px solid var(--border-default); display: flex; align-items: center; justify-content: center; color: var(--aquamarine);"><Icon name={s.icon} size={22} /></span>
              <div>
                <div style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-h3);">{s.name}</div>
                <div style="margin-top: 0.5rem; color: var(--text-secondary);">{s.headline}</div>
              </div>
            </a>
          </Reveal>
        ))
      }
    </div>
  </section>

  <FinalCTA />
</StretchLayout>
